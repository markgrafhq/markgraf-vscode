{
  "name": "markgraf-vscode",
  "displayName": "Markgraf",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:markgraf.preview",
    "onLanguage:markdown",
    "onLanguage:markgraf"
  ],
  "main": "./output/Main/index.js",
  "contributes": {
    "languages": [
      {
        "id": "markgraf",
        "aliases": [
          "Markgraf"
        ],
        "extensions": [
          ".markgraf"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Markgraf",
      "properties": {
        "markgraf.serverCommand": {
          "type": "string",
          "default": "",
          "description": "Path to a Markgraf language server script. Leave empty to use the bundled server."
        },
        "markgraf.serverRuntime": {
          "type": "string",
          "default": "",
          "description": "Runtime command for the Markgraf language server. Leave empty to use VS Code\u2019s Node runtime."
        }
      }
    },
    "grammars": [
      {
        "language": "markgraf",
        "scopeName": "source.markgraf",
        "path": "./syntaxes/markgraf.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "markgraf.preview",
        "title": "Preview",
        "category": "Markgraf",
        "icon": "$(preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markgraf.preview",
          "when": "resourceLangId == markgraf",
          "group": "navigation"
        }
      ]
    },
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./embed/dist/markgraf-embed.js",
      "./markdown/preview.js"
    ],
    "markdown.previewStyles": [
      "./embed/dist/markgraf-embed.css",
      "./markdown/preview.css"
    ]
  },
  "scripts": {
    "build": "PATH=/opt/homebrew/bin:$PATH spago build",
    "vscode:prepublish": "bun run build"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "purescript": "^0.15.15",
    "spago": "^1.0.3"
  },
  "type": "module",
  "publisher": "markgrafhq",
  "description": "Markgraf language support, diagnostics, and live preview for VS Code.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markgrafhq/markgraf-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/markgrafhq/markgraf-vscode/issues"
  },
  "homepage": "https://github.com/markgrafhq/markgraf-vscode#readme",
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "markgraf",
    "diagram",
    "preview",
    "language-server"
  ]
}
