{
  "scopeName": "source.markgraf",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#attributes" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.markgraf", "match": "#.*$" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.markgraf",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.markgraf", "match": "\\\\." }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.markgraf", "match": "\\b(?:seed|keyframe|still|title|inside|par|seq|enter|exit|via)\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.markgraf", "match": "(?:\\+node|\\-node|~node|\\+edge|\\-edge|~edge|->|=>)" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.markgraf", "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b" }
      ]
    },
    "attributes": {
      "patterns": [
        { "name": "entity.other.attribute-name.markgraf", "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*(?=\\s*:)" }
      ]
    },
    "identifiers": {
      "patterns": [
        { "name": "variable.other.markgraf", "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b" }
      ]
    }
  }
}
